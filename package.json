{
    "name": "vina-flight-control",
    "version": "0.1.0",
    "private": true,
    "description": "Bun monorepo for the VinaFlightControl drone flight controller ecosystem",
    "workspaces": [
        "apps/*",
        "packages/*",
        "workers/*"
    ],
    "scripts": {
        "dev": "bun run --filter '*' dev",
        "dev:web": "bun run --filter '@vinafc/web' dev",
        "dev:desktop": "bun run --filter '@vinafc/desktop' dev",
        "dev:api": "bun run --filter '@vinafc/api' dev",
        "build": "bun run --filter '*' build",
        "build:web": "bun run --filter '@vinafc/web' build",
        "build:desktop": "bun run --filter '@vinafc/desktop' build",
        "build:api": "bun run --filter '@vinafc/api' build",
        "test": "bun run --filter '*' test",
        "lint": "bun run --filter '*' lint",
        "format": "bun run --filter '*' format",
        "typecheck": "bun run --filter '*' typecheck",
        "clean": "bun run --filter '*' clean"
    },
    "devDependencies": {
        "typescript": "^5.7.3"
    },
    "engines": {
        "bun": ">=1.3.10"
    },
    "packageManager": "bun@1.3.10"
}