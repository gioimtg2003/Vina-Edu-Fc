{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "@vinauav/config/tsconfig.nextjs.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        ".next/types/**/*.ts",
        "next.config.ts",
        "tailwind.config.ts"
    ],
    "exclude": [
        "node_modules",
        ".next",
        "out"
    ]
}