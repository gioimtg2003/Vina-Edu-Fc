{
    "compilerOptions": {
        "target": "es2022",
        "module": "es2022",
        "lib": [
            "es2022"
        ],
        "types": [
            "@cloudflare/workers-types"
        ],
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "allowJs": true,
        "esModuleInterop": true
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts",
        "worker-configuration.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}