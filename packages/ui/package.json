{
    "name": "@vinauav/ui",
    "version": "0.1.0",
    "private": true,
    "description": "Shared UI component library for VinaUAV — built on shadcn/ui, Tailwind CSS, and react-hook-form",
    "type": "module",
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
